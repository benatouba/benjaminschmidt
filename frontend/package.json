{
  "name": "frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview --host",
    "typecheck": "vue-tsc --noEmit -p tsconfig.app.json",
    "lint:oxlint": "oxlint --tsconfig tsconfig.json --vue-plugin --deny-warnings src",
    "lint:vue": "eslint --max-warnings=0 \"src/**/*.vue\"",
    "lint": "pnpm run lint:oxlint && pnpm run lint:vue",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@fontsource/merriweather": "^5.2.11",
    "@fontsource/source-sans-3": "^5.2.9",
    "@mdi/js": "^7.4.47",
    "vue": "^3.5.32",
    "vue-i18n": "^11.3.1",
    "vue-router": "^5.0.4",
    "vuetify": "^4.0.5"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.2.0",
    "eslint-plugin-vue": "^10.8.0",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.5",
    "vite-plugin-vuetify": "^2.1.3",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.6"
  }
}
