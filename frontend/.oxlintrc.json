{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "vue"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "rules": {
    "no-debugger": "error",
    "no-console": ["warn", { "allow": ["warn", "error"] }],
    "typescript/consistent-type-imports": "error"
  },
  "env": {
    "builtin": true,
    "browser": true,
    "es2022": true
  },
  "globals": {},
  "ignorePatterns": ["dist/**", "node_modules/**"],
  "overrides": [],
  "options": {
    "denyWarnings": true
  }
}
